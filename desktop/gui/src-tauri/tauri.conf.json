{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WeUnix",
  "version": "0.2.0",
  "identifier": "cn.kismet.weunix",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WeUnix",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 700,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["../../../app_icon.ico"],
    "resources": [
      "resources/backend_api.py",
      "resources/weunix-backend.exe",
      "resources/weunix_core.py",
      "resources/config_helpers.py",
      "resources/room_helpers.py",
      "resources/rate_limit.py",
      "resources/secret_store.py"
    ]
  }
}
